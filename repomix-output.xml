}

.brand-text { display: flex; flex-direction: column; line-height: 1.1; }
.brand-text span:last-child { font-size: 11px; font-weight: 500; color: var(--text-mute); letter-spacing: .04em; text-transform: uppercase; }

.sidebar-section { padding: 6px 14px; }

.sidebar-section-title {
  font-size: 10.5px;
