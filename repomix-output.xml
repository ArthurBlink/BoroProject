/* ============================================================
   Boro · Live Streams — design tokens & global styles
   ============================================================ */

:root {
  --font-sans: "Plus Jakarta Sans", "Manrope", ui-sans-serif, sans-serif;
  --font-mono: "JetBrains Mono", "IBM Plex Mono", ui-monospace, monospace;
  --r-xs: 6px;
  --r-sm: 8px;
  --r-md: 12px;
  --r-lg: 16px;
  --r-xl: 22px;
  --r-pill: 999px;
  --ease: cubic-bezier(.2, .8, .2, 1);
  --t-fast: 140ms;
  --t-base: 220ms;
  --t-slow: 360ms;
}

:root,
[data-theme="dark"] {
  --bg: #0A1020;
  --bg-grad: radial-gradient(1200px 800px at 80% -10%, rgba(0,212,242,.06), transparent 60%),
             radial-gradient(900px 700px at -10% 110%, rgba(89, 84, 255, .05), transparent 60%),
             #0A1020;
  --surface: #111A2E;
  --surface-2: #16223B;
  --surface-3: #1C2A47;
  --border: rgba(255,255,255,.07);
  --border-strong: rgba(255,255,255,.14);
  --text: #EAF0FB;
  --text-dim: #A4B1CC;
  --text-mute: #6E7C99;
  --accent: #25E0FF;
  --accent-ink: #051820;
  --accent-soft: rgba(37, 224, 255, .14);
  --online: #2EE6A6;
  --online-glow: rgba(46, 230, 166, .55);
  --offline: #6E7C99;
  --danger: #FF6A82;
  --warn: #FFB547;
  --shadow-card: 0 1px 0 rgba(255,255,255,.04) inset, 0 8px 24px -12px rgba(0,0,0,.6);
  --shadow-pop: 0 20px 50px -20px rgba(0,0,0,.7);
  --thumb-bg: linear-gradient(135deg, #182542 0%, #0E1830 100%);
  --code-bg: rgba(37, 224, 255, .07);
  --code-ink: #6BE9FF;
}

[data-theme="light"] {
  --bg: #F4F6FB;
  --bg-grad: radial-gradient(1100px 700px at 85% -10%, rgba(0,153,184,.07), transparent 60%),
             radial-gradient(900px 700px at -10% 110%, rgba(89, 84, 255, .05), transparent 60%),
             #F4F6FB;
  --surface: #FFFFFF;
  --surface-2: #F7F9FD;
  --surface-3: #EEF2F8;
  --border: rgba(15,26,46,.08);
  --border-strong: rgba(15,26,46,.16);
  --text: #0E1A2E;
  --text-dim: #3D4A66;
  --text-mute: #788299;
  --accent: #0093B0;
  --accent-ink: #FFFFFF;
  --accent-soft: rgba(0, 147, 176, .12);
  --online: #12B071;
  --online-glow: rgba(18, 176, 113, .45);
  --offline: #98A1B5;
  --danger: #D8425A;
  --warn: #C77900;
  --shadow-card: 0 1px 0 rgba(255,255,255,.6) inset, 0 1px 2px rgba(15,26,46,.04), 0 8px 22px -14px rgba(15,26,46,.18);
  --shadow-pop: 0 18px 50px -20px rgba(15,26,46,.28);
  --thumb-bg: linear-gradient(135deg, #E9EFF7 0%, #D9E2F0 100%);
  --code-bg: rgba(0, 147, 176, .08);
  --code-ink: #006C82;
}

*, *::before, *::after { box-sizing: border-box; }

html, body {
  margin: 0;
  padding: 0;
  font-family: var(--font-sans);
  font-feature-settings: "ss01", "cv11";
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
}

body {
  background: var(--bg-grad);
  background-attachment: fixed;
  transition: background-color var(--t-base) var(--ease), color var(--t-base) var(--ease);
}

button {
  font-family: inherit;
  font-size: inherit;
  border: 0;
  background: transparent;
  color: inherit;
  cursor: pointer;
  padding: 0;
}

button:disabled { opacity: .5; cursor: not-allowed; }

input, select, textarea {
  font-family: inherit;
  font-size: inherit;
  color: inherit;
}

::selection { background: var(--accent); color: var(--accent-ink); }

/* ============================================================
   App shell
   ============================================================ */

.app {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 280px 1fr;
  transition: grid-template-columns var(--t-slow) var(--ease);
}

.app[data-sidebar="closed"] {
  grid-template-columns: 0 1fr;
}

/* ============================================================
   Sidebar
   ============================================================ */

.sidebar {
  border-right: 1px solid var(--border);
  background: var(--surface);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

[data-theme="dark"] .sidebar { background: #0C1426; }

.sidebar-head {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 22px 22px 16px;
}

.brand {
  display: flex;
  align-items: center;
  gap: 11px;
  font-weight: 700;
  letter-spacing: -.01em;
  font-size: 16px;
}

.brand-mark {
  width: 32px;
  height: 32px;
  border-radius: 9px;
  background: linear-gradient(135deg, var(--accent), color-mix(in oklab, var(--accent), #5358FF 40%));
  display: grid;
  place-items: center;
  color: var(--accent-ink);
  font-weight: 800;
