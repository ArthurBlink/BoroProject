}

.account-row:hover { background: var(--surface-2); }
.account-row[data-active="true"] { background: var(--surface-2); }
.account-row[data-active="true"]::before {
  content: "";
  position: absolute;
  left: -14px;
  top: 12px;
  bottom: 12px;
