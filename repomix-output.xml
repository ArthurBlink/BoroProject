.foot-user { display: flex; align-items: center; gap: 10px; min-width: 0; }
.foot-user .account-avatar { background: linear-gradient(135deg, #5358FF, #25E0FF); color: #fff; }
.foot-user-name { font-size: 13px; font-weight: 600; letter-spacing: -.01em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.foot-user-mail { font-size: 11px; color: var(--text-mute); }

.icon-btn {
